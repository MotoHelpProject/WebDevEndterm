{
  "info": {
    "name": "MotoHelp API",
    "description": "API collection for MotoHelp — social radar for bikers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"rider1\",\n  \"email\": \"rider1@mail.com\",\n  \"password\": \"secret123\",\n  \"phone\": \"+77001234567\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.access);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"rider1\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/me/"
          }
        },
        {
          "name": "Update Location",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/me/location/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 51.1801,\n  \"longitude\": 71.4460\n}"
            }
          }
        },
        {
          "name": "Save Transport",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/transport/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Yamaha\",\n  \"model\": \"R1\",\n  \"color\": \"Чёрный\",\n  \"plate_number\": \"40 09BL\"\n}"
            }
          }
        },
        {
          "name": "Get Transport",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/transport/"
          }
        }
      ]
    },
    {
      "name": "Help Requests",
      "item": [
        {
          "name": "Create Request (SOS)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/requests/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"GAS\",\n  \"latitude\": 51.1801,\n  \"longitude\": 71.4460,\n  \"radius_km\": 15,\n  \"description\": \"Закончился бензин\"\n}"
            }
          }
        },
        {
          "name": "My Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/requests/"
          }
        },
        {
          "name": "Nearby Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/requests/nearby/?lat=51.18&lon=71.44&radius=20",
              "query": [
                { "key": "lat", "value": "51.18" },
                { "key": "lon", "value": "71.44" },
                { "key": "radius", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Request Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/requests/1/"
          }
        },
        {
          "name": "Accept Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/requests/1/",
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"accept\"\n}" }
          }
        },
        {
          "name": "Complete Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/requests/1/",
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"complete\"\n}" }
          }
        },
        {
          "name": "Cancel Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/requests/1/",
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"cancel\"\n}" }
          }
        },
        {
          "name": "Delete Request",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/requests/1/"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/messages/?request_id=1",
              "query": [{ "key": "request_id", "value": "1" }]
            }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/messages/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_id\": 1,\n  \"content\": \"Еду к вам!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Ratings",
      "item": [
        {
          "name": "Submit Rating",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/ratings/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_id\": 1,\n  \"score\": 5,\n  \"comment\": \"Отличная помощь!\"\n}"
            }
          }
        }
      ]
    }
  ]
}
